<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>A股市场资金证据雷达</title>
  <style>
    :root { color-scheme: light; --bg:#f4f5f7; --card:#fff; --text:#172033; --muted:#687386; --line:#dfe3ea; --accent:#334155; }
    * { box-sizing:border-box; }
    body { margin:0; background:var(--bg); color:var(--text); font-family:Inter,"PingFang SC","Microsoft YaHei",sans-serif; line-height:1.65; }
    main { max-width:1180px; margin:auto; padding:28px 18px 60px; }
    h1 { margin:0 0 6px; font-size:30px; }
    h2 { margin-top:34px; border-bottom:1px solid var(--line); padding-bottom:8px; }
    h3 { margin:0 0 10px; }
    .muted { color:var(--muted); }
    .notice { border:1px solid #cbd5e1; background:#f8fafc; padding:14px 16px; border-radius:10px; margin:16px 0; }
    .demo { border-color:#d6b562; background:#fffaf0; }
    .grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(210px,1fr)); gap:14px; }
    .card { background:var(--card); border:1px solid var(--line); border-radius:12px; padding:16px; box-shadow:0 1px 3px rgba(15,23,42,.04); }
    .metric { font-size:24px; font-weight:700; margin-top:4px; }
    .pill { display:inline-block; border:1px solid var(--line); border-radius:999px; padding:2px 9px; font-size:13px; color:var(--muted); }
    .state-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(310px,1fr)); gap:14px; }
    ul { padding-left:20px; }
    table { width:100%; border-collapse:collapse; background:var(--card); }
    th,td { border-bottom:1px solid var(--line); padding:9px; text-align:left; vertical-align:top; font-size:14px; }
    details { margin-top:10px; }
    footer { margin-top:40px; color:var(--muted); font-size:13px; }
    a { color:#334e68; }
  </style>
</head>
<body>
<main>
  <h1>A股市场资金证据雷达</h1>
  <div class="muted">{{ report.trade_date }} · {{ report.report_stage }} · {{ report.data_mode }}</div>
  {% if report.report_stage == "demo" %}<div class="notice demo"><strong>演示模式：</strong>页面数据不代表真实市场。</div>{% endif %}
  <div class="notice">先看数据状态和已确认事实，再看解释。系统不识别所谓“主力真实意图”，也不输出交易建议。</div>

  <div class="grid">
    <div class="card"><div class="muted">市场状态</div><div class="metric">{{ report.market_state.label }}</div><span class="pill">置信度 {{ report.market_state.confidence_level }}</span></div>
    <div class="card"><div class="muted">上涨覆盖率</div><div class="metric">{{ report.market_state.metrics.market.breadth_ratio|pct if report.market_state.metrics.market.available else "数据不足" }}</div></div>
    <div class="card"><div class="muted">市场成交额</div><div class="metric">{{ report.market_state.metrics.market.total_amount|money if report.market_state.metrics.market.available else "数据不足" }}</div></div>
    <div class="card"><div class="muted">融资余额近5日</div><div class="metric">{{ report.market_state.metrics.margin.change_ratio_5d|pct if report.market_state.metrics.margin.available else "数据不足" }}</div></div>
  </div>

  <h2>数据源状态</h2>
  <table><thead><tr><th>来源</th><th>级别</th><th>状态</th><th>日期</th><th>说明</th></tr></thead><tbody>
  {% for source in report.source_quality %}<tr><td>{{ source.display_name }}</td><td>{{ source.evidence_level }}</td><td>{{ "可用" if source.available else "缺失" }}</td><td>{{ source.actual_date or "-" }}</td><td>{{ source.error_message or "-" }}</td></tr>{% endfor %}
  </tbody></table>

  <h2>板块状态</h2>
  {% for label, states in groups.items() %}
  <h3>{{ label }}</h3>
  <div class="state-grid">
    {% for state in states %}
    <article class="card">
      <h3>{{ state.sector_name }}</h3><span class="pill">{{ state.confidence_level }}</span>
      <p><strong>已确认事实</strong></p><ul>{% for item in state.supporting_evidence %}<li>{{ item }}</li>{% endfor %}</ul>
      {% if state.counter_evidence %}<p><strong>反向证据</strong></p><ul>{% for item in state.counter_evidence %}<li>{{ item }}</li>{% endfor %}</ul>{% endif %}
      <details><summary>无法确认与后续条件</summary><ul>{% for item in state.unknowns %}<li>{{ item }}</li>{% endfor %}{% for item in state.next_confirmation_conditions %}<li>{{ item }}</li>{% endfor %}</ul></details>
    </article>
    {% endfor %}
  </div>
  {% endfor %}

  <h2>限制</h2>
  <div class="card"><ul>{% for item in report.global_unknowns %}<li>{{ item }}</li>{% endfor %}</ul></div>
  <footer>仅用于学习、观察和复盘，不构成投资建议。<br><a href="api/v3/latest.json">查看结构化 JSON</a> · <a href="report.md">查看 Markdown 日报</a></footer>
</main>
</body>
</html>
